  {
   "cell_type": "markdown",
   "id": "section-fetch",
   "metadata": {},
   "source": [
    "## 3. Data Fetcher — Open-Meteo API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fetch-function",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_sensor_reading(sensor: dict) -> dict:\n",
    "    \"\"\"\n",
    "    Fetch current weather data from Open-Meteo for a given sensor location.\n",
    "    Returns a structured payload mimicking an IoT sensor event.\n",
    "    \"\"\"\n",
    "    params = {\n",
    "        'latitude': sensor['latitude'],\n",
    "        'longitude': sensor['longitude'],\n",
    "        'current': ','.join(WEATHER_VARIABLES),\n",
    "        'timezone': 'Asia/Jakarta',\n",
    "        'forecast_days': 1\n",
    "    }\n",
    "\n",
    "    try:\n",
    "        response = requests.get(OPEN_METEO_BASE, params=params, timeout=10)\n",
    "        response.raise_for_status()\n",
    "        data = response.json()\n",
    "        current = data.get('current', {})\n",
    "\n",
    "        payload = {\n",
    "            'sensor_id':          sensor['sensor_id'],\n",
    "            'city':               sensor['city'],\n",
    "            'latitude':           sensor['latitude'],\n",
    "            'longitude':          sensor['longitude'],\n",
    "            'event_time':         datetime.now(timezone.utc).isoformat(),\n",
    "            'temperature_c':      current.get('temperature_2m'),\n",
    "            'humidity_pct':       current.get('relative_humidity_2m'),\n",
    "            'apparent_temp_c':    current.get('apparent_temperature'),\n",
    "            'precipitation_mm':   current.get('precipitation'),\n",
    "            'weather_code':       current.get('weather_code'),\n",
    "            'wind_speed_kmh':     current.get('wind_speed_10m'),\n",
    "            'wind_direction_deg': current.get('wind_direction_10m'),\n",
    "            'ingestion_source':   'open-meteo-api',\n",
    "        }\n",
    "        return payload\n",
    "\n",
    "    except requests.exceptions.RequestException as e:\n",
    "        print(f\"⚠️  Error fetching data for {sensor['city']}: {e}\")\n",
    "        return None\n",
    "\n",
    "\n",
    "# ── Quick test ──────────────────────────────────────────────────\n",
    "test_reading = fetch_sensor_reading(SENSOR_LOCATIONS[0])\n",
    "if test_reading:\n",
    "    print(\"✅ Sample reading from Jakarta sensor:\")\n",
    "    print(json.dumps(test_reading, indent=2))\n",
    "else:\n",
    "    print(\"❌ Failed to fetch. Check internet connection.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-kafka-producer",
   "metadata": {},
   "source": [
    "## 4. Kafka Producer — Stream IoT Events"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "kafka-producer",
   "metadata": {},
   "outputs": [],
   "source": [
    "def create_kafka_producer():\n",
    "    \"\"\"Initialize and return a Kafka producer.\"\"\"\n",
    "    producer = KafkaProducer(\n",
    "        bootstrap_servers=KAFKA_BOOTSTRAP_SERVERS,\n",
    "        value_serializer=lambda v: json.dumps(v).encode('utf-8'),\n",
    "        acks='all',              # wait for all replicas to acknowledge\n",
    "        retries=3,\n",
    "        compression_type='gzip'\n",
    "    )\n",
    "    print(f\"✅ Kafka Producer connected to {KAFKA_BOOTSTRAP_SERVERS}\")\n",
    "    return producer\n",
    "\n",
    "\n",
    "def stream_sensor_data(producer, interval_seconds: int = 60, max_cycles: int = 5):\n",
    "    \"\"\"\n",
    "    Continuously poll Open-Meteo API and publish each sensor reading\n",
    "    to the Kafka topic. Set max_cycles=None for infinite streaming.\n",
    "    \"\"\"\n",
    "    cycle = 0\n",
    "    print(f\"🚀 Starting stream — polling every {interval_seconds}s\")\n",
    "    print(f\"   Topic: {KAFKA_TOPIC}\")\n",
    "    print(\"-\" * 55)\n",
    "\n",
    "    while max_cycles is None or cycle < max_cycles:\n",
    "        cycle += 1\n",
    "        print(f\"\\n📡 Cycle {cycle} — {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "\n",
    "        published = 0\n",
    "        for sensor in SENSOR_LOCATIONS:\n",
    "            payload = fetch_sensor_reading(sensor)\n",
    "            if payload:\n",
    "                future = producer.send(\n",
    "                    KAFKA_TOPIC,\n",
    "                    key=sensor['sensor_id'].encode('utf-8'),\n",
    "                    value=payload\n",
    "                )\n",
    "                try:\n",
    "                    future.get(timeout=10)\n",
    "                    print(f\"   ✉️  Published: {sensor['sensor_id']} | \"\n",
    "                          f\"Temp={payload['temperature_c']}°C | \"\n",
    "                          f\"Humidity={payload['humidity_pct']}%\")\n",
    "                    published += 1\n",
    "                except KafkaError as e:\n",
    "                    print(f\"   ❌ Kafka error for {sensor['sensor_id']}: {e}\")\n",
    "\n",
    "        producer.flush()\n",
    "        print(f\"   ✅ {published}/{len(SENSOR_LOCATIONS)} events published\")\n",
    "\n",
    "        if max_cycles is None or cycle < max_cycles:\n",
    "            print(f\"   ⏳ Waiting {interval_seconds}s...\")\n",
    "            time.sleep(interval_seconds)\n",
    "\n",
    "\n",
    "# ── Run producer (demo mode: 3 cycles, 5s interval) ─────────────\n",
    "producer = create_kafka_producer()\n",
    "stream_sensor_data(producer, interval_seconds=5, max_cycles=3)\n",
    "producer.close()\n",
    "print(\"\\n🏁 Producer finished\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-spark",
   "metadata": {},
   "source": [
    "## 5. PySpark Structured Streaming — Process & Aggregate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "pyspark-streaming",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── PySpark Session ─────────────────────────────────────────────\n",
    "spark = SparkSession.builder \\\n",
    "    .appName('IoTWeatherStreamingPipeline') \\\n",
    "    .config('spark.jars.packages',\n",
    "            'org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0,'\n",
    "            'org.postgresql:postgresql:42.7.1') \\\n",
    "    .config('spark.sql.streaming.checkpointLocation', '/tmp/checkpoint/iot_weather') \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.sparkContext.setLogLevel('WARN')\n",
    "print(\"✅ Spark session started:\", spark.version)\n",
    "\n",
    "# ── Schema definition ───────────────────────────────────────────\n",
    "SENSOR_SCHEMA = StructType([\n",
    "    StructField('sensor_id',          StringType(),  True),\n",
    "    StructField('city',               StringType(),  True),\n",
    "    StructField('latitude',           DoubleType(),  True),\n",
    "    StructField('longitude',          DoubleType(),  True),\n",
    "    StructField('event_time',         StringType(),  True),\n",
    "    StructField('temperature_c',      DoubleType(),  True),\n",
    "    StructField('humidity_pct',       DoubleType(),  True),\n",
    "    StructField('apparent_temp_c',    DoubleType(),  True),\n",
    "    StructField('precipitation_mm',   DoubleType(),  True),\n",
    "    StructField('weather_code',       IntegerType(), True),\n",
    "    StructField('wind_speed_kmh',     DoubleType(),  True),\n",
    "    StructField('wind_direction_deg', DoubleType(),  True),\n",
    "    StructField('ingestion_source',   StringType(),  True),\n",
    "])\n",
    "\n",
    "# ── Read from Kafka ─────────────────────────────────────────────\n",
    "kafka_stream_df = spark.readStream \\\n",
    "    .format('kafka') \\\n",
    "    .option('kafka.bootstrap.servers', ','.join(KAFKA_BOOTSTRAP_SERVERS)) \\\n",
    "    .option('subscribe', KAFKA_TOPIC) \\\n",
    "    .option('startingOffsets', 'latest') \\\n",
    "    .option('failOnDataLoss', 'false') \\\n",
    "    .load()\n",
    "\n",
    "# ── Parse JSON payload ──────────────────────────────────────────\n",
    "parsed_df = kafka_stream_df \\\n",
    "    .select(\n",
    "        from_json(\n",
    "            col('value').cast('string'),\n",
    "            SENSOR_SCHEMA\n",
    "        ).alias('data')\n",
    "    ) \\\n",
    "    .select('data.*') \\\n",
    "    .withColumn('event_time', to_timestamp(col('event_time')))\n",
    "\n",
    "# ── Windowed aggregation (5-minute tumbling window per city) ────\n",
    "aggregated_df = parsed_df \\\n",
    "    .withWatermark('event_time', '2 minutes') \\\n",
    "    .groupBy(\n",
    "        window(col('event_time'), '5 minutes'),\n",
    "        col('city'),\n",
    "        col('sensor_id')\n",
    "    ) \\\n",
    "    .agg(\n",
    "        avg('temperature_c').alias('avg_temperature_c'),\n",
    "        avg('humidity_pct').alias('avg_humidity_pct'),\n",
    "        spark_max('temperature_c').alias('max_temperature_c'),\n",
    "        spark_min('temperature_c').alias('min_temperature_c'),\n",
    "        avg('wind_speed_kmh').alias('avg_wind_speed_kmh'),\n",
    "        avg('precipitation_mm').alias('total_precipitation_mm'),\n",
    "        count('*').alias('event_count')\n",
    "    )\n",
    "\n",
    "# ── Write raw stream to PostgreSQL ──────────────────────────────\n",
    "def write_to_postgres(batch_df, batch_id):\n",
    "    \"\"\"Write each micro-batch to PostgreSQL.\"\"\"\n",
    "    rows = batch_df.collect()\n",
    "    if not rows:\n",
    "        return\n",
    "\n",
    "    conn = psycopg2.connect(**POSTGRES_CONFIG)\n",
    "    cur = conn.cursor()\n",
    "\n",
    "    insert_sql = \"\"\"\n",
    "        INSERT INTO iot_sensor_readings (\n",
    "            sensor_id, city, latitude, longitude, event_time,\n",
    "            temperature_c, humidity_pct, apparent_temp_c,\n",
    "            precipitation_mm, weather_code, wind_speed_kmh,\n",
    "            wind_direction_deg, ingestion_source\n",
    "        ) VALUES (%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s)\n",
    "        ON CONFLICT (sensor_id, event_time) DO NOTHING;\n",
    "    \"\"\"\n",
    "    data = [\n",
    "        (r.sensor_id, r.city, r.latitude, r.longitude, r.event_time,\n",
    "         r.temperature_c, r.humidity_pct, r.apparent_temp_c,\n",
    "         r.precipitation_mm, r.weather_code, r.wind_speed_kmh,\n",
    "         r.wind_direction_deg, r.ingestion_source)\n",
    "        for r in rows\n",
    "    ]\n",
    "    execute_batch(cur, insert_sql, data)\n",
    "    conn.commit()\n",
    "    cur.close()\n",
    "    conn.close()\n",
    "    print(f\"✅ Batch {batch_id}: wrote {len(rows)} rows to PostgreSQL\")\n",
    "\n",
    "\n",
    "# ── Start streaming query ────────────────────────────────────────\n",
    "query = parsed_df.writeStream \\\n",
    "    .foreachBatch(write_to_postgres) \\\n",
    "    .outputMode('append') \\\n",
    "    .trigger(processingTime='30 seconds') \\\n",
    "    .start()\n",
    "\n",
    "print(\"🚀 Streaming query started. Awaiting termination...\")\n",
    "# query.awaitTermination()  # uncomment for production"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-bq",
   "metadata": {},
   "source": [
    "## 6. Sync to BigQuery (Data Warehouse)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "bigquery-sync",
   "metadata": {},
   "outputs": [],
   "source": [
    "def sync_postgres_to_bigquery(hours_back: int = 1):\n",
    "    \"\"\"\n",
    "    Pull recent records from PostgreSQL and load them into BigQuery.\n",
    "    Called hourly by Airflow DAG.\n",
    "    \"\"\"\n",
    "    # 1. Extract from PostgreSQL\n",
    "    conn = psycopg2.connect(**POSTGRES_CONFIG)\n",
    "    query = f\"\"\"\n",
    "        SELECT * FROM iot_sensor_readings\n",
    "        WHERE event_time >= NOW() - INTERVAL '{hours_back} hours'\n",
    "          AND synced_to_bq = FALSE;\n",
    "    \"\"\"\n",
    "    df = pd.read_sql(query, conn)\n",
    "    conn.close()\n",
    "\n",
    "    if df.empty:\n",
    "        print(\"ℹ️  No new records to sync\")\n",
    "        return 0\n",
    "\n",
    "    # 2. Load to BigQuery\n",
    "    bq_client = bigquery.Client(project=BQ_PROJECT_ID)\n",
    "    table_id = f\"{BQ_PROJECT_ID}.{BQ_DATASET}.{BQ_TABLE}\"\n",
    "\n",
    "    job_config = bigquery.LoadJobConfig(\n",
    "        write_disposition=bigquery.WriteDisposition.WRITE_APPEND,\n",
    "        schema=[\n",
    "            bigquery.SchemaField('sensor_id',          'STRING'),\n",
    "            bigquery.SchemaField('city',               'STRING'),\n",
    "            bigquery.SchemaField('latitude',           'FLOAT64'),\n",
    "            bigquery.SchemaField('longitude',          'FLOAT64'),\n",
    "            bigquery.SchemaField('event_time',         'TIMESTAMP'),\n",
    "            bigquery.SchemaField('temperature_c',      'FLOAT64'),\n",
    "            bigquery.SchemaField('humidity_pct',       'FLOAT64'),\n",
    "            bigquery.SchemaField('apparent_temp_c',    'FLOAT64'),\n",
    "            bigquery.SchemaField('precipitation_mm',   'FLOAT64'),\n",
    "            bigquery.SchemaField('weather_code',       'INTEGER'),\n",
    "            bigquery.SchemaField('wind_speed_kmh',     'FLOAT64'),\n",
    "            bigquery.SchemaField('wind_direction_deg', 'FLOAT64'),\n",
    "            bigquery.SchemaField('ingestion_source',   'STRING'),\n",
    "        ]\n",
    "    )\n",
    "\n",
    "    job = bq_client.load_table_from_dataframe(df, table_id, job_config=job_config)\n",
    "    job.result()  # wait for completion\n",
    "\n",
    "    print(f\"✅ Synced {len(df)} records to BigQuery → {table_id}\")\n",
    "    return len(df)\n",
    "\n",
    "\n",
    "# Trigger sync (normally called by Airflow)\n",
    "# synced_count = sync_postgres_to_bigquery(hours_back=1)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-analytics",
   "metadata": {},
   "source": [
    "## 7. Analytics — Query BigQuery for Insights"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "analytics",
   "metadata": {},
   "outputs": [],
   "source": [
    "def run_analytics_query(query_name: str, sql: str) -> pd.DataFrame:\n",
    "    \"\"\"Execute a BigQuery SQL query and return results as DataFrame.\"\"\"\n",
    "    bq_client = bigquery.Client(project=BQ_PROJECT_ID)\n",
    "    print(f\"\\n📊 Running: {query_name}\")\n",
    "    df = bq_client.query(sql).to_dataframe()\n",
    "    print(df.to_string(index=False))\n",
    "    return df\n",
    "\n",
    "\n",
    "# ── Query 1: Hourly average temperature per city (last 24h) ─────\n",
    "q1 = f\"\"\"\n",
    "SELECT\n",
    "    city,\n",
    "    TIMESTAMP_TRUNC(event_time, HOUR) AS hour,\n",
    "    ROUND(AVG(temperature_c), 2)  AS avg_temp_c,\n",
    "    ROUND(AVG(humidity_pct), 1)   AS avg_humidity,\n",
    "    ROUND(MAX(wind_speed_kmh), 1) AS max_wind_kmh,\n",
    "    COUNT(*)                      AS readings\n",
    "FROM `{BQ_PROJECT_ID}.{BQ_DATASET}.{BQ_TABLE}`\n",
    "WHERE event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 24 HOUR)\n",
    "GROUP BY city, hour\n",
    "ORDER BY city, hour DESC;\n",
    "\"\"\"\n",
    "\n",
    "# ── Query 2: Cities with highest temperature anomaly ────────────\n",
    "q2 = f\"\"\"\n",
    "WITH city_avg AS (\n",
    "    SELECT city,\n",
    "           AVG(temperature_c) AS overall_avg\n",
    "    FROM `{BQ_PROJECT_ID}.{BQ_DATASET}.{BQ_TABLE}`\n",
    "    WHERE event_time >= TIMESTAMP_SUB(CURRENT_TIMESTAMP(), INTERVAL 7 DAY)\n",
    "    GROUP BY city\n",
    "),\n",
    "latest AS (\n",
    "    SELECT city, temperature_c,\n",
    "           ROW_NUMBER() OVER (PARTITION BY city ORDER BY event_time DESC) AS rn\n",
    "    FROM `{BQ_PROJECT_ID}.{BQ_DATASET}.{BQ_TABLE}`\n",
    ")\n",
    "SELECT\n",
    "    l.city,\n",
    "    ROUND(l.temperature_c, 2)                    AS current_temp_c,\n",
    "    ROUND(c.overall_avg, 2)                      AS avg_7d_temp_c,\n",
    "    ROUND(l.temperature_c - c.overall_avg, 2)    AS anomaly_delta\n",
    "FROM latest l\n",
    "JOIN city_avg c ON l.city = c.city\n",
    "WHERE l.rn = 1\n",
    "ORDER BY ABS(anomaly_delta) DESC;\n",
    "\"\"\"\n",
    "\n",
    "# Run analytics\n",
    "# df1 = run_analytics_query(\"Hourly Temperature by City\", q1)\n",
    "# df2 = run_analytics_query(\"Temperature Anomaly Detection\", q2)\n",
    "print(\"📝 Queries ready. Uncomment to run against BigQuery.\")"
