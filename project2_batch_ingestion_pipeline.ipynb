    "## 8. Analytics on Redshift"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "analytics",
   "metadata": {},
   "outputs": [],
   "source": [
    "def query_redshift(sql: str, label: str = '') -> pd.DataFrame:\n",
    "    rs_url = (\n",
    "        f\"postgresql+psycopg2://{REDSHIFT_CONFIG['user']}:{REDSHIFT_CONFIG['password']}\"\n",
    "        f\"@{REDSHIFT_CONFIG['host']}:{REDSHIFT_CONFIG['port']}/{REDSHIFT_CONFIG['database']}\"\n",
    "    )\n",
    "    engine = create_engine(rs_url)\n",
    "    df = pd.read_sql(sql, engine)\n",
    "    if label:\n",
    "        print(f\"\\n📊 {label}\")\n",
    "        print(df.to_string(index=False))\n",
    "    return df\n",
    "\n",
    "\n",
    "# ── Insight 1: Top languages by activity score ───────────────────\n",
    "q_lang = \"\"\"\n",
    "SELECT language,\n",
    "       COUNT(*)                                  AS repo_count,\n",
    "       ROUND(AVG(stars), 0)                      AS avg_stars,\n",
    "       ROUND(AVG(activity_score), 2)             AS avg_activity_score,\n",
    "       ROUND(AVG(stars_per_day), 2)              AS avg_stars_per_day\n",
    "FROM batch_ingestion.github_repositories\n",
    "WHERE batch_date = CURRENT_DATE\n",
    "GROUP BY language\n",
    "ORDER BY avg_activity_score DESC;\n",
    "\"\"\"\n",
    "\n",
    "# ── Insight 2: Correlation weather & open-source activity ────────\n",
    "q_correlation = \"\"\"\n",
    "SELECT\n",
    "    w.city,\n",
    "    ROUND(AVG(w.temp_mean_c), 1)       AS avg_temp_c,\n",
    "    SUM(CASE WHEN w.is_rainy THEN 1 ELSE 0 END) AS rainy_days,\n",
    "    COUNT(DISTINCT w.date)             AS total_days\n",
    "FROM batch_ingestion.historical_weather w\n",
    "WHERE w.date >= CURRENT_DATE - 30\n",
    "GROUP BY w.city\n",
    "ORDER BY avg_temp_c DESC;\n",
    "\"\"\"\n",
    "\n",
    "# df_lang = query_redshift(q_lang, 'Top Languages by Activity Score')\n",
    "# df_corr = query_redshift(q_correlation, 'Weather Summary by City')\n",
    "print(\"📝 Analytics queries ready — uncomment to run against Redshift\")"
   ]
