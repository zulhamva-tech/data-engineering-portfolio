   "cell_type": "markdown",
   "id": "section-github",
   "metadata": {},
   "source": [
    "## 2. Source 1 — GitHub Trending Repositories API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "github-fetcher",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_github_repos(language: str, per_page: int = 30, page: int = 1) -> List[Dict]:\n",
    "    \"\"\"\n",
    "    Fetch trending GitHub repos for a given language.\n",
    "    Uses GitHub Search API: https://api.github.com/search/repositories\n",
    "    \"\"\"\n",
    "    since_date = (datetime.now() - timedelta(days=30)).strftime('%Y-%m-%d')\n",
    "    url = 'https://api.github.com/search/repositories'\n",
    "    params = {\n",
    "        'q': f'language:{language} created:>{since_date} stars:>50',\n",
    "        'sort': 'stars',\n",
    "        'order': 'desc',\n",
    "        'per_page': per_page,\n",
    "        'page': page\n",
    "    }\n",
    "\n",
    "    resp = requests.get(url, headers=GITHUB_HEADERS, params=params, timeout=15)\n",
    "    resp.raise_for_status()\n",
    "    items = resp.json().get('items', [])\n",
    "\n",
    "    results = []\n",
    "    for repo in items:\n",
    "        results.append({\n",
    "            'repo_id':          repo['id'],\n",
    "            'repo_name':        repo['full_name'],\n",
    "            'description':      (repo.get('description') or '')[:500],\n",
    "            'language':         language,\n",
    "            'stars':            repo['stargazers_count'],\n",
    "            'forks':            repo['forks_count'],\n",
    "            'open_issues':      repo['open_issues_count'],\n",
    "            'watchers':         repo['watchers_count'],\n",
    "            'is_fork':          repo['fork'],\n",
    "            'license':          (repo.get('license') or {}).get('spdx_id', 'NONE'),\n",
    "            'created_at':       repo['created_at'],\n",
    "            'pushed_at':        repo['pushed_at'],\n",
    "            'size_kb':          repo['size'],\n",
    "            'topics':           ','.join(repo.get('topics', [])),\n",
    "            'html_url':         repo['html_url'],\n",
    "            'ingested_at':      datetime.utcnow().isoformat(),\n",
    "            'batch_date':       str(date.today()),\n",
    "        })\n",
    "    return results\n",
    "\n",
    "\n",
    "def fetch_all_repos() -> List[Dict]:\n",
    "    \"\"\"Fetch repos for all configured programming languages.\"\"\"\n",
    "    all_repos = []\n",
    "    for lang in PROGRAMMING_LANGUAGES:\n",
    "        try:\n",
    "            repos = fetch_github_repos(lang, per_page=REPOS_PER_LANGUAGE)\n",
    "            all_repos.extend(repos)\n",
    "            print(f\"   ✅ {lang}: fetched {len(repos)} repos\")\n",
    "            time.sleep(1.2)  # respect rate limit\n",
    "        except Exception as e:\n",
    "            print(f\"   ❌ {lang}: {e}\")\n",
    "    return all_repos\n",
    "\n",
    "\n",
    "print(\"🔍 Fetching GitHub trending repos...\")\n",
    "github_repos = fetch_all_repos()\n",
    "print(f\"\\n✅ Total repos fetched: {len(github_repos)}\")\n",
    "print(\"\\nSample record:\")\n",
    "print(json.dumps(github_repos[0] if github_repos else {}, indent=2))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-weather-hist",
   "metadata": {},
   "source": [
    "## 3. Source 2 — Open-Meteo Historical Weather API"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "weather-hist-fetcher",
   "metadata": {},
   "outputs": [],
   "source": [
    "def fetch_historical_weather(location: Dict,\n",
    "                              start: date,\n",
    "                              end: date) -> List[Dict]:\n",
    "    \"\"\"\n",
    "    Fetch historical daily weather from Open-Meteo Archive API.\n",
    "    Free, no API key required.\n",
    "    \"\"\"\n",
    "    params = {\n",
    "        'latitude':   location['latitude'],\n",
    "        'longitude':  location['longitude'],\n",
    "        'start_date': str(start),\n",
    "        'end_date':   str(end),\n",
    "        'daily': ','.join([\n",
    "            'temperature_2m_max', 'temperature_2m_min', 'temperature_2m_mean',\n",
    "            'precipitation_sum', 'rain_sum', 'snowfall_sum',\n",
    "            'wind_speed_10m_max', 'wind_gusts_10m_max', 'wind_direction_10m_dominant',\n",
    "            'shortwave_radiation_sum', 'et0_fao_evapotranspiration'\n",
    "        ]),\n",
    "        'timezone': 'Asia/Jakarta'\n",
    "    }\n",
    "\n",
    "    resp = requests.get(OM_HISTORICAL_BASE, params=params, timeout=20)\n",
    "    resp.raise_for_status()\n",
    "    data = resp.json()\n",
    "    daily = data.get('daily', {})\n",
    "    dates = daily.get('time', [])\n",
    "\n",
    "    records = []\n",
    "    for i, d in enumerate(dates):\n",
    "        records.append({\n",
    "            'city':                       location['city'],\n",
    "            'latitude':                   location['latitude'],\n",
    "            'longitude':                  location['longitude'],\n",
    "            'date':                       d,\n",
    "            'temp_max_c':                 daily.get('temperature_2m_max', [None])[i],\n",
    "            'temp_min_c':                 daily.get('temperature_2m_min', [None])[i],\n",
    "            'temp_mean_c':                daily.get('temperature_2m_mean', [None])[i],\n",
    "            'precipitation_sum_mm':       daily.get('precipitation_sum', [None])[i],\n",
    "            'rain_sum_mm':                daily.get('rain_sum', [None])[i],\n",
    "            'wind_speed_max_kmh':         daily.get('wind_speed_10m_max', [None])[i],\n",
    "            'wind_gusts_max_kmh':         daily.get('wind_gusts_10m_max', [None])[i],\n",
    "            'wind_direction_dominant_deg':daily.get('wind_direction_10m_dominant', [None])[i],\n",
    "            'solar_radiation_sum':        daily.get('shortwave_radiation_sum', [None])[i],\n",
    "            'batch_date':                 str(date.today()),\n",
    "            'ingested_at':                datetime.utcnow().isoformat(),\n",
    "            'source':                     'open-meteo-historical'\n",
    "        })\n",
    "    return records\n",
    "\n",
    "\n",
    "def fetch_all_historical_weather() -> List[Dict]:\n",
    "    all_records = []\n",
    "    for loc in LOCATIONS:\n",
    "        try:\n",
    "            records = fetch_historical_weather(loc, START_DATE, END_DATE)\n",
    "            all_records.extend(records)\n",
    "            print(f\"   ✅ {loc['city']}: {len(records)} daily records ({START_DATE} → {END_DATE})\")\n",
    "        except Exception as e:\n",
    "            print(f\"   ❌ {loc['city']}: {e}\")\n",
    "    return all_records\n",
    "\n",
    "\n",
    "print(\"🌦️ Fetching historical weather data...\")\n",
    "weather_records = fetch_all_historical_weather()\n",
    "print(f\"\\n✅ Total weather records: {len(weather_records)}\")\n",
    "print(\"\\nSample record:\")\n",
    "print(json.dumps(weather_records[0] if weather_records else {}, indent=2))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-kafka-batch",
   "metadata": {},
   "source": [
    "## 4. Kafka Producer — Publish Batch Events"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "kafka-batch",
   "metadata": {},
   "outputs": [],
   "source": [
    "def publish_batch_to_kafka(records: List[Dict], topic: str, key_field: str):\n",
    "    \"\"\"Publish a list of records to a Kafka topic.\"\"\"\n",
    "    producer = KafkaProducer(\n",
    "        bootstrap_servers=KAFKA_BOOTSTRAP_SERVERS,\n",
    "        value_serializer=lambda v: json.dumps(v, default=str).encode('utf-8'),\n",
    "        acks='all',\n",
    "        batch_size=65536,       # 64 KB batches\n",
    "        linger_ms=50,           # wait 50ms to fill batches\n",
    "        compression_type='gzip'\n",
    "    )\n",
    "\n",
    "    success, failures = 0, 0\n",
    "    for record in records:\n",
    "        try:\n",
    "            key = str(record.get(key_field, 'unknown')).encode('utf-8')\n",
    "            producer.send(topic, key=key, value=record)\n",
    "            success += 1\n",
    "        except Exception as e:\n",
    "            failures += 1\n",
    "            print(f\"⚠️  Failed to publish: {e}\")\n",
    "\n",
    "    producer.flush()\n",
    "    producer.close()\n",
    "    print(f\"\\n✅ Published to '{topic}': {success} success / {failures} failures\")\n",
    "\n",
    "\n",
    "# ── Publish both datasets to Kafka ──────────────────────────────\n",
    "print(\"📨 Publishing GitHub repos to Kafka...\")\n",
    "publish_batch_to_kafka(github_repos,    KAFKA_TOPIC_GITHUB,  key_field='repo_id')\n",
    "\n",
    "print(\"\\n📨 Publishing weather records to Kafka...\")\n",
    "publish_batch_to_kafka(weather_records, KAFKA_TOPIC_WEATHER, key_field='city')"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-pyspark-batch",
   "metadata": {},
   "source": [
    "## 5. PySpark Batch Processing — Transform & Enrich"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "pyspark-batch",
   "metadata": {},
   "outputs": [],
   "source": [
    "spark = SparkSession.builder \\\n",
    "    .appName('BatchIngestionPipeline') \\\n",
    "    .config('spark.jars.packages',\n",
    "            'org.apache.spark:spark-sql-kafka-0-10_2.12:3.5.0,'\n",
    "            'org.postgresql:postgresql:42.7.1') \\\n",
    "    .getOrCreate()\n",
    "\n",
    "spark.sparkContext.setLogLevel('WARN')\n",
    "print(\"✅ Spark session started\")\n",
    "\n",
    "# ── 5a. Read GitHub data from Kafka (batch) ──────────────────────\n",
    "GITHUB_SCHEMA = StructType([\n",
    "    StructField('repo_id',     IntegerType(), True),\n",
    "    StructField('repo_name',   StringType(),  True),\n",
    "    StructField('description', StringType(),  True),\n",
    "    StructField('language',    StringType(),  True),\n",
    "    StructField('stars',       IntegerType(), True),\n",
    "    StructField('forks',       IntegerType(), True),\n",
    "    StructField('open_issues', IntegerType(), True),\n",
    "    StructField('watchers',    IntegerType(), True),\n",
    "    StructField('is_fork',     BooleanType(), True),\n",
    "    StructField('license',     StringType(),  True),\n",
    "    StructField('created_at',  StringType(),  True),\n",
    "    StructField('pushed_at',   StringType(),  True),\n",
    "    StructField('size_kb',     IntegerType(), True),\n",
    "    StructField('topics',      StringType(),  True),\n",
    "    StructField('html_url',    StringType(),  True),\n",
    "    StructField('batch_date',  StringType(),  True),\n",
    "])\n",
    "\n",
    "github_kafka_df = spark.read \\\n",
    "    .format('kafka') \\\n",
    "    .option('kafka.bootstrap.servers', ','.join(KAFKA_BOOTSTRAP_SERVERS)) \\\n",
    "    .option('subscribe', KAFKA_TOPIC_GITHUB) \\\n",
    "    .option('startingOffsets', 'earliest') \\\n",
    "    .option('endingOffsets', 'latest') \\\n",
    "    .load()\n",
    "\n",
    "github_parsed_df = github_kafka_df \\\n",
    "    .select(from_json(col('value').cast('string'), GITHUB_SCHEMA).alias('d')) \\\n",
    "    .select('d.*')\n",
    "\n",
    "# ── 5b. Transformations ─────────────────────────────────────────\n",
    "github_clean_df = github_parsed_df \\\n",
    "    .withColumn('description', trim(col('description'))) \\\n",
    "    .withColumn('language',    lower(col('language'))) \\\n",
    "    .withColumn('license',     when(col('license').isNull(), 'UNLICENSED').otherwise(col('license'))) \\\n",
    "    .withColumn('created_at',  to_timestamp(col('created_at'))) \\\n",
    "    .withColumn('pushed_at',   to_timestamp(col('pushed_at'))) \\\n",
    "    .withColumn('repo_age_days', datediff(current_timestamp(), col('created_at'))) \\\n",
    "    .withColumn('stars_per_day',\n",
    "                spark_round(col('stars') / (col('repo_age_days') + 1), 2)) \\\n",
    "    .withColumn('activity_score',\n",
    "                spark_round(\n",
    "                    col('stars') * 0.5 + col('forks') * 0.3 + col('watchers') * 0.2, 2\n",
    "                )) \\\n",
    "    .dropDuplicates(['repo_id'])\n",
    "\n",
    "print(f\"✅ GitHub: {github_clean_df.count()} repos after dedup & transform\")\n",
    "github_clean_df.show(5, truncate=50)\n",
    "\n",
    "# ── 5c. Weather transformations ──────────────────────────────────\n",
    "WEATHER_SCHEMA = StructType([\n",
    "    StructField('city',                          StringType(),  True),\n",
    "    StructField('date',                          StringType(),  True),\n",
    "    StructField('temp_max_c',                    DoubleType(),  True),\n",
    "    StructField('temp_min_c',                    DoubleType(),  True),\n",
    "    StructField('temp_mean_c',                   DoubleType(),  True),\n",
    "    StructField('precipitation_sum_mm',          DoubleType(),  True),\n",
    "    StructField('wind_speed_max_kmh',            DoubleType(),  True),\n",
    "    StructField('wind_gusts_max_kmh',            DoubleType(),  True),\n",
    "    StructField('solar_radiation_sum',           DoubleType(),  True),\n",
    "    StructField('batch_date',                    StringType(),  True),\n",
    "])\n",
    "\n",
    "weather_kafka_df = spark.read \\\n",
    "    .format('kafka') \\\n",
    "    .option('kafka.bootstrap.servers', ','.join(KAFKA_BOOTSTRAP_SERVERS)) \\\n",
    "    .option('subscribe', KAFKA_TOPIC_WEATHER) \\\n",
    "    .option('startingOffsets', 'earliest') \\\n",
    "    .option('endingOffsets', 'latest') \\\n",
    "    .load()\n",
    "\n",
    "weather_df = weather_kafka_df \\\n",
    "    .select(from_json(col('value').cast('string'), WEATHER_SCHEMA).alias('d')) \\\n",
    "    .select('d.*') \\\n",
    "    .withColumn('date', to_date(col('date'))) \\\n",
    "    .withColumn('temp_range_c',\n",
    "                spark_round(col('temp_max_c') - col('temp_min_c'), 2)) \\\n",
    "    .withColumn('is_rainy',\n",
    "                when(col('precipitation_sum_mm') > 1.0, True).otherwise(False)) \\\n",
    "    .dropDuplicates(['city', 'date'])\n",
    "\n",
    "print(f\"\\n✅ Weather: {weather_df.count()} daily records after dedup & transform\")\n",
    "weather_df.show(5)"
   ]
  },
  {
   "cell_type": "markdown",
