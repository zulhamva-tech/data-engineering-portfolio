   "source": [
    "def write_spark_df_to_postgres(df, table: str, mode: str = 'append'):\n",
    "    \"\"\"Write a PySpark DataFrame to PostgreSQL via JDBC.\"\"\"\n",
    "    jdbc_url = (\n",
    "        f\"jdbc:postgresql://{POSTGRES_CONFIG['host']}:{POSTGRES_CONFIG['port']}\"\n",
    "        f\"/{POSTGRES_CONFIG['database']}\"\n",
    "    )\n",
    "    props = {\n",
    "        'user':     POSTGRES_CONFIG['user'],\n",
    "        'password': POSTGRES_CONFIG['password'],\n",
    "        'driver':   'org.postgresql.Driver'\n",
    "    }\n",
    "    df.write.jdbc(url=jdbc_url, table=table, mode=mode, properties=props)\n",
    "    print(f\"✅ Written to PostgreSQL table: {table}\")\n",
    "\n",
    "\n",
    "# write_spark_df_to_postgres(github_clean_df, 'github_repositories')\n",
    "# write_spark_df_to_postgres(weather_df,      'historical_weather')\n",
    "print(\"📝 PostgreSQL write ready — uncomment to execute\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-redshift",
   "metadata": {},
   "source": [
    "## 7. Load to Amazon Redshift (Data Warehouse)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "redshift-load",
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_to_redshift_via_s3(df: pd.DataFrame,\n",
    "                             schema: str,\n",
    "                             table: str,\n",
    "                             s3_path: str):\n",
    "    \"\"\"\n",
    "    1. Write DataFrame to S3 as Parquet\n",
    "    2. COPY from S3 to Redshift (fastest bulk load method)\n",
    "    \"\"\"\n",
    "    bucket  = REDSHIFT_CONFIG['s3_bucket']\n",
    "    iam_arn = REDSHIFT_CONFIG['iam_role']\n",
    "\n",
    "    # Step 1: Upload to S3\n",
    "    s3 = boto3.client('s3')\n",
    "    parquet_buffer = df.to_parquet(index=False)\n",
    "    s3.put_object(Bucket=bucket, Key=s3_path, Body=parquet_buffer)\n",
    "    s3_full_path = f's3://{bucket}/{s3_path}'\n",
    "    print(f\"   ✅ Uploaded to {s3_full_path}\")\n",
    "\n",
    "    # Step 2: COPY to Redshift\n",
    "    rs_url = (\n",
    "        f\"postgresql+psycopg2://{REDSHIFT_CONFIG['user']}:{REDSHIFT_CONFIG['password']}\"\n",
    "        f\"@{REDSHIFT_CONFIG['host']}:{REDSHIFT_CONFIG['port']}/{REDSHIFT_CONFIG['database']}\"\n",
    "    )\n",
    "    engine = create_engine(rs_url)\n",
    "    copy_sql = f\"\"\"\n",
    "        COPY {schema}.{table}\n",
    "        FROM '{s3_full_path}'\n",
    "        IAM_ROLE '{iam_arn}'\n",
    "        FORMAT AS PARQUET;\n",
    "    \"\"\"\n",
    "    with engine.connect() as conn:\n",
    "        conn.execute(copy_sql)\n",
    "    print(f\"   ✅ Loaded to Redshift: {schema}.{table}\")\n",
    "\n",
    "\n",
    "# ── Convert Spark → Pandas → S3 → Redshift ──────────────────────\n",
    "batch_tag = date.today().strftime('%Y%m%d')\n",
    "\n",
    "# load_to_redshift_via_s3(\n",
    "#     df=github_clean_df.toPandas(),\n",
    "#     schema='batch_ingestion',\n",
    "#     table='github_repositories',\n",
    "#     s3_path=f'batch_pipeline/github/dt={batch_tag}/repos.parquet'\n",
    "# )\n",
    "\n",
    "# load_to_redshift_via_s3(\n",
    "#     df=weather_df.toPandas(),\n",
    "#     schema='batch_ingestion',\n",
    "#     table='historical_weather',\n",
    "#     s3_path=f'batch_pipeline/weather/dt={batch_tag}/weather.parquet'\n",
    "# )\n",
    "\n",
    "print(\"📝 Redshift load ready — uncomment to execute\")"
   ]
